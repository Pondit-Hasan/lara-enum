{
    "name": "mahmudul/lara-enum",
    "description": "A lightweight Laravel enum enhancement package with labels, descriptions and helpers.",
    "keywords": ["laravel", "enum", "attributes", "description", "labels"],
    "homepage": "https://github.com/Pondit-Hasan/lara-enum",
    "support": {
        "issues": "https://github.com/Pondit-Hasan/lara-enum/issues",
        "source": "https://github.com/Pondit-Hasan/lara-enum"
    },
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Mahmudul Hasan",
            "email": "mahmudul.bd.90@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.25",
        "driftingly/rector-laravel": "^2.1",
        "pestphp/pest": "^4.1",
        "pestphp/pest-plugin-laravel": "^4.0",
        "orchestra/testbench": "^10.6"
    },
    "autoload": {
        "psr-4": {
            "Mahmudul\\LaraEnum\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mahmudul\\LaraEnum\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mahmudul\\LaraEnum\\LaraEnumServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "format": "pint"
    },
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
